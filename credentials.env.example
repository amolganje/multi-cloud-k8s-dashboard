# =============================================================================
# Dashboard Credentials — REPLACE PLACEHOLDERS BEFORE RUNNING
# =============================================================================
# This is the ONLY file you need to edit with secrets.
# start.sh sources this file automatically.
#
# DO NOT commit this file to version control.
# Add to .gitignore: credentials.env
# =============================================================================

# --- OCP (OpenShift) ---------------------------------------------------------
# User must exist on all target OCP clusters (e.g. cluster-admin or
# a role with read access to all relevant namespaces).
export OCP_USERNAME="<OCP_USER_HERE>"
export OCP_PASSWORD="<OCP_PASS_HERE>"

# --- AWS (for EKS clusters) --------------------------------------------------
# IAM user / role with permissions:
#   - eks:DescribeCluster, eks:ListClusters
#   - sts:GetCallerIdentity (always granted)
#   - The IAM identity must also be mapped in the EKS aws-auth ConfigMap
#     to a Kubernetes group/user with read access to the cluster.
export AWS_ACCESS_KEY_ID="<AWS_ACCESS_KEY_HERE>"
export AWS_SECRET_ACCESS_KEY="<AWS_SECRET_KEY_HERE>"
export AWS_REGION="us-east-1"
